# --- Supabase (required for auth, forum, feedback, moderation) ---
# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Project Settings -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site URL (used for canonical URLs, sitemap, robots, OG tags) ---
# Production example: https://whv-guide-australia.com
# Leave empty locally to fall back to the Vercel/default URL.
NEXT_PUBLIC_SITE_URL=

# --- Google AdSense ad unit slot ids (optional) ---
# Create ad units in AdSense, then paste their data-ad-slot ids here.
# When empty, ad areas render nothing (no placeholder boxes).
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=

# --- Discord notifications (optional) ---
# Discord channel -> Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL.
# When a report or feedback/request is submitted, a message is posted to this channel.
# Server-side only (do NOT prefix with NEXT_PUBLIC). Leave empty to disable notifications.
DISCORD_WEBHOOK_URL=
